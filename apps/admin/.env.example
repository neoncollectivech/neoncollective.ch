# Production: events-api root (auth client uses {VITE_EVENTS_API_URL}/admin/auth)
VITE_EVENTS_API_URL=https://api.neoncollective.ch/neo-events-api

# Public site origin for invite and login links (no trailing slash)
VITE_PUBLIC_SITE_URL=http://localhost:3000
# Locale prefix in copied invite URLs (default: en)
# VITE_PUBLIC_SITE_DEFAULT_LOCALE=en

# GitHub Pages sets VITE_ADMIN_BASE=/admin/ in CI. Local dev uses `/` (default).
# VITE_ADMIN_BASE=/admin/

# events-api: add your GitHub Pages origin to ADMIN_ALLOWED_ORIGIN (e.g. https://neoncollective.ch).
# Google OAuth redirect URI (Google Cloud Console) is on the API, not this app:
#   {EVENTS_API_PUBLIC_URL}/admin/auth/callback/google
# e.g. https://api.neoncollective.ch/neo-events-api/admin/auth/callback/google
