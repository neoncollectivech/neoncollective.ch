# Production: events-api root (Bearer check-in uses this base URL)
VITE_EVENTS_API_URL=https://api.neoncollective.ch/neo-events-api

# Public site origin for PWA manifest start_url (no trailing slash)
VITE_PUBLIC_SITE_URL=https://neoncollective.ch

# CDN / GitHub Pages: set VITE_DOOR_BASE=/door/ in CI. Local dev uses `/` (default).
# VITE_DOOR_BASE=/door/
#
# PWA: production build is installable at https://neoncollective.ch/door/ (HTTPS required).
# Ensure events-api CORS allows the door origin (EVENTS_ALLOWED_ORIGIN).
# Optional: Settings → App build label (CI sets VITE_DOOR_BUILD_LABEL to git SHA)
# VITE_DOOR_BUILD_LABEL=local
