# Public site origin (Stripe return URLs, magic links). Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe API Cloud Function URL
# Local dev (.env.local):       http://localhost:8081
# Production (.env.production): https://europe-west6-neo-tickets-shop.cloudfunctions.net/stripe-api
NEXT_PUBLIC_STRIPE_API_URL=http://localhost:8081

# Stripe publishable key (pk_test_… / pk_live_…) — required for event checkout (Stripe Elements).
# Same Stripe account as STRIPE_SECRET_KEY on events-api. Dashboard → Developers → API keys.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Events API (Hono on Cloud Run or local dev, e.g. http://localhost:8082)
NEXT_PUBLIC_EVENTS_API_URL=http://localhost:8082

# Comma-separated PUBLIC event slugs to pre-render at build time (default: demo). Each slug is built for every locale (de, en, it).
# Do not set to empty — that breaks `output: "export"`. Invite-only events use `/events/private?slug=…` at runtime and do not need a slug here.
# NEXT_PUBLIC_EVENT_SLUGS=demo,seed-public

# R2 public asset domain (must match events-api R2_PUBLIC_BASE_URL; no trailing slash).
# Enables responsive srcset via Cloudflare Image Resizing (fit=scale-down, format=auto).
# Example: https://assets.neoncollective.ch
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=
