# Stripe secret key (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...

# Allowed CORS origin (your site's domain)
ALLOWED_ORIGIN=https://neoncollective.ch

# Static site origin for validating checkout/portal return URLs
PUBLIC_SITE_URL=https://neoncollective.ch

# Resend: FROM_EMAIL must be on a domain verified under Domains. API keys with "Sending access"
# must have that same domain linked to the key (or use "Full access"). SDK returns { error }, not throws.
RESEND_API_KEY=re_...
FROM_EMAIL=tickets@yourdomain.com
FROM_NAME=NEON

# Random secret for HMAC-signing magic link tokens (generate with: openssl rand -hex 32)
MAGIC_LINK_SECRET=

# Public URL of this Cloud Function (used to build magic link URLs)
API_BASE_URL=https://europe-west6-your-project.cloudfunctions.net/stripeApi
