# cp env.yaml.example env.yaml — then: pnpm deploy:gcp events-api
#
# Required for Cloud Run startup (disables pino-pretty in @neon/server-kit):
NODE_ENV: "production"
#
#   cp functions/events-api/env.yaml.example functions/events-api/env.yaml

# --- Database (required) ---
DATABASE_URL: "FILL_IN"

# --- CORS / public site (required) ---
PUBLIC_SITE_URL: "https://neoncollective.ch"
EVENTS_ALLOWED_ORIGIN: "https://neoncollective.ch"
ALLOWED_ORIGIN: "https://neoncollective.ch"

# --- Stripe (required) ---
STRIPE_SECRET_KEY: "FILL_IN"
STRIPE_WEBHOOK_SECRET: "FILL_IN"

# --- Resend (required) ---
RESEND_API_KEY: "FILL_IN"
FROM_EMAIL: "hello@neonclub.ch"
FROM_NAME: "NEON"

# --- Twilio (required for phone OTP) ---
TWILIO_ACCOUNT_SID: "FILL_IN"
TWILIO_AUTH_TOKEN: "FILL_IN"
TWILIO_MESSAGING_SERVICE_SID: "FILL_IN"
# TWILIO_FROM: "NEON"

# --- Session ---
PARTICIPANT_SESSION_MAX_AGE_SEC: "2592000"
EVENT_SESSION_CROSS_SITE: "1"

# --- Admin / Better Auth (required) ---
# Public Cloud Function root (auth at {EVENTS_API_PUBLIC_URL}/admin/auth)
EVENTS_API_PUBLIC_URL: "https://api.neoncollective.ch/neo-events-api"
BETTER_AUTH_SECRET: "FILL_IN"
GOOGLE_CLIENT_ID: "FILL_IN"
GOOGLE_CLIENT_SECRET: "FILL_IN"
ADMIN_ALLOWED_ORIGIN: "https://neoncollective.ch"
BETTER_AUTH_CROSS_SUBDOMAIN: "1"
BETTER_AUTH_COOKIE_DOMAIN: ".neoncollective.ch"

# Google Cloud Console → OAuth redirect URI (not the admin SPA URL):
#   {EVENTS_API_PUBLIC_URL}/admin/auth/callback/google

# --- Cloudflare R2 (event images; optional until admin uploads are used) ---
# R2 bucket CORS: allow PUT + GET from admin SPA origins.
# R2_PUBLIC_BASE_URL: custom domain, no trailing slash (e.g. https://assets.neoncollective.ch)
R2_ACCOUNT_ID: "FILL_IN"
R2_ACCESS_KEY_ID: "FILL_IN"
R2_SECRET_ACCESS_KEY: "FILL_IN"
R2_BUCKET_NAME: "FILL_IN"
R2_PUBLIC_BASE_URL: "FILL_IN"
