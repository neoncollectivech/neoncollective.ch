# Neon Postgres (pooled connection string recommended)
DATABASE_URL=

# After setting DATABASE_URL:
#   pnpm db:events-api:migrate:local   # from repo root; loads functions/events-api/.env.local
#   # or: DATABASE_URL=… pnpm db:events-api:migrate
# Neon: run migrations on the *direct* (non-pooler) connection URL; use the same DB URL the
# running events-api uses. Verify focal columns: SELECT focal_x FROM event_images LIMIT 1;
# Schema changes: pnpm db:events-api:generate  (then commit drizzle/)
# Same scripts exist on @neon/events-api via pnpm --filter @neon/events-api …
# CORS (credentialed fetch): `Access-Control-Allow-Origin` must echo the browser Origin, never `*`.
# Allowed origins = PUBLIC_SITE_URL origin + comma-separated EVENTS_ALLOWED_ORIGIN + ALLOWED_ORIGIN.
# Each value must be a full URL (http://localhost:3000). localhost and 127.0.0.1 are mirrored in dev.
EVENTS_ALLOWED_ORIGIN=http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_…). Production: Stripe Dashboard → Webhooks → your endpoint.
# E2E Playwright (`pnpm test:e2e`): set E2E_TEST_MODE=1 on events-api (config does this); optional E2E_TEST_OTP=EEEEEE
# Optional: `pnpm db:events-api:seed:local` — creates Filo via invite on seed-invite-only (person materialized from invite, not inserted directly)
# Optional: `pnpm db:events-api:seed:e2e` — invite-only checkout seed for Playwright (see test/README.md)
# SEED_EMAIL=you@example.com
# SEED_PHONE_E164=+41791234567

# Local: install Stripe CLI (brew install stripe/stripe-cli/stripe — not on npm), run
#   pnpm stripe:listen
# from the repo root, copy the printed whsec_ into this file while events-api dev runs on PORT.
# Checkout: the browser calls POST /checkout/confirm after payment; the webhook reconciles the
# same order idempotently (pending → paid). Either path can run first; both are safe.
# Refunds: admin POST /admin/orders/:id/refund only calls Stripe; DB state (refunded, admission
# revoked, invite redemptions removed) is applied on charge.refunded — keep stripe listen running locally.
# Stripe webhook events to enable: payment_intent.succeeded, payment_intent.payment_failed,
# payment_intent.canceled (failed/canceled mark pending orders as failed), charge.refunded.
STRIPE_WEBHOOK_SECRET=

# SumUp Cloud API (Door POS — Solo readers). Affiliate key: https://developer.sumup.com/affiliate-keys
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=
SUMUP_AFFILIATE_KEY=
SUMUP_APP_ID=
# Optional: verify POST /pos/webhooks/sumup (x-payload-signature)
SUMUP_WEBHOOK_SECRET=
# Used for SumUp checkout return_url webhook target
EVENTS_API_PUBLIC_URL=http://localhost:8082

# Resend: https://resend.com/api-keys — verify your sending domain under Domains first.
# FROM_EMAIL must use that domain. If the API key uses "Sending access", its linked domain
# must match FROM_EMAIL; otherwise create a key with "Full access" or edit the key's domain.
# The Node SDK returns { error } instead of throwing; logs will show "Resend rejected email" with the API message if it fails.
RESEND_API_KEY=
FROM_EMAIL=
FROM_NAME=

# Origin of the static Next site — registration returnUrl must match this origin (same protocol+host+port).
PUBLIC_SITE_URL=http://localhost:3000
# Locale segment for admin-exported login links (default en; keep in sync with apps/admin public-site config).
PUBLIC_SITE_DEFAULT_LOCALE=en

# Participant session cookie: default SameSite=None; Secure (static Next + separate API).
# EVENT_SESSION_CROSS_SITE=0 — SameSite=Lax (only when the cookie is first-party to the API host).
EVENT_SESSION_CROSS_SITE=

# Twilio SMS (registration sign-in by phone).
# Prefer TWILIO_MESSAGING_SERVICE_SID (Messaging → Services in Twilio Console): attach your +E.164 number
# and/or an approved alphanumeric sender there — avoids juggling From rules in env.
# Otherwise set TWILIO_FROM to either:
#   - A Twilio-owned number in E.164 (e.g. +15551234567), or
#   - An alphanumeric sender ID: max 11 characters after removing spaces (Twilio API). Examples: NEON, NEONCLUB.
#   Long strings like "NEON Collective" are rejected by Twilio (not a US-vs-CH rule).
# SMS body stays one GSM-7 segment; keep PUBLIC_SITE_URL / slugs ASCII and reasonably short.
# Credentials (one of):
#   - Auth: TWILIO_ACCOUNT_SID (AC...) + TWILIO_AUTH_TOKEN
#   - Restricted API key: TWILIO_ACCOUNT_SID (AC...) + TWILIO_API_KEY_SID (SK...) + TWILIO_API_KEY_SECRET
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM=

# Long-lived participant session cookie (seconds), e.g. 30 days
PARTICIPANT_SESSION_MAX_AGE_SEC=2592000

# Public events-api URL (same value as VITE_EVENTS_API_URL / NEXT_PUBLIC_EVENTS_API_URL)
EVENTS_API_PUBLIC_URL=http://localhost:8082

# Admin portal — Better Auth (Google SSO, @neonclub.ch only)
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_ALLOWED_ORIGIN=http://localhost:5173
# Google OAuth → Credentials → Authorized redirect URIs (not the admin SPA URL):
#   {EVENTS_API_PUBLIC_URL}/admin/auth/callback/google
# Local: http://localhost:8082/admin/auth/callback/google
# Production: https://api.neoncollective.ch/neo-events-api/admin/auth/callback/google
# Production: BETTER_AUTH_CROSS_SUBDOMAIN=1 and BETTER_AUTH_COOKIE_DOMAIN=.neoncollective.ch
BETTER_AUTH_CROSS_SUBDOMAIN=
BETTER_AUTH_COOKIE_DOMAIN=

PORT=8082

# --- Cloudflare R2 (event images) ---
# Public custom domain for browser img src (no trailing slash), e.g. https://assets.neoncollective.ch
# Bucket CORS must allow PUT + GET from admin origins (http://localhost:5173, production admin host).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
