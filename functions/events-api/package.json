{
  "name": "@neon/events-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=.env.local src/dev.ts",
    "lint": "eslint src --ext .ts -c ../../.eslintrc.node.json --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:push:local": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed:local": "dotenv -e .env.local -- tsx src/scripts/seed-local-test-data.ts"
  },
  "dependencies": {
    "@neon/admin-crud": "workspace:*",
    "@neon/server-kit": "workspace:*",
    "better-auth": "^1.2.0",
    "@google-cloud/functions-framework": "^3.4.0",
    "@hono/arktype-validator": "^2.0.0",
    "@hono/node-server": "^1.13.0",
    "arktype": "^2.1.0",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.7.0",
    "libphonenumber-js": "^1.13.2",
    "postgres": "^3.4.5",
    "stripe": "^17.0.0",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "7.2.0",
    "@typescript-eslint/parser": "7.2.0",
    "@types/node": "^22.0.0",
    "eslint": "^8.57.0",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
