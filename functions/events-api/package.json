{
  "name": "@neon/events-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=.env.local src/dev.ts",
    "lint": "eslint src --ext .ts -c .eslintrc.json --max-warnings 0",
    "knip": "pnpm -w knip --workspace functions/events-api",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:repair-migrations": "tsx src/scripts/repair-migration-journal.ts",
    "db:repair-migrations:local": "dotenv -e .env.local -- tsx src/scripts/repair-migration-journal.ts",
    "db:push": "drizzle-kit push",
    "db:push:local": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed:local": "pnpm db:repair-migrations:local && dotenv -e .env.local -- tsx src/scripts/seed-local-test-data.ts",
    "db:seed:e2e": "pnpm db:repair-migrations:local && dotenv -e .env.local -- tsx src/scripts/seed-e2e-checkout.ts",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@google-cloud/functions-framework": "^3.4.0",
    "@hono/arktype-validator": "^2.0.0",
    "@hono/node-server": "^1.13.0",
    "@neon/resource-api": "workspace:*",
    "@neon/server-kit": "workspace:*",
    "@neon/site-locales": "workspace:*",
    "@neondatabase/serverless": "^0.10.4",
    "@sumup/sdk": "^0.1.6",
    "arktype": "^2.1.0",
    "better-auth": "^1.2.0",
    "csv-stringify": "^6.5.2",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.7.0",
    "jose": "^6.2.3",
    "libphonenumber-js": "^1.13.2",
    "stripe": "^17.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "7.2.0",
    "@typescript-eslint/parser": "7.2.0",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^8.57.0",
    "postgres": "^3.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
